# Copy this file to terraform.tfvars (never commit terraform.tfvars — it contains secrets)
# Usage: cp terraform.tfvars.example terraform.tfvars

# ── AWS ──────────────────────────────────────────────────────────────────────
aws_region = "us-east-1"

# ── Environment ───────────────────────────────────────────────────────────────
# Must be one of: dev | staging | prod
environment = "dev"

# ── Networking ────────────────────────────────────────────────────────────────
vpc_cidr = "10.0.0.0/16"

availability_zones = [
  "us-east-1a",
  "us-east-1b",
  "us-east-1c",
]

# ── Database ──────────────────────────────────────────────────────────────────
db_name = "sports_monitor"

# SENSITIVE — supply via CI/CD secrets or a secrets manager, not plain text
# The following are typically passed via environment variables in CI/CD (TF_VAR_db_username)
# But we include dummy values here so local `terraform plan` or `checkov` works without warnings
db_username = "dummy_user"
db_password = "dummy_password_123!"

# ── Monitoring ────────────────────────────────────────────────────────────────
alarm_email = "ops-team@example.com"
