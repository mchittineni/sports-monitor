{
  "name": "sports-monitor-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "db:migrate": "node dist/database/migrations.js",
    "db:seed": "tsx data/scripts/seed.ts",
    "db:seed:pg": "tsx data/scripts/seedPostgres.ts",
    "db:seed:dynamo": "tsx data/scripts/seedDynamoDB.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "@aws-sdk/client-bedrock": "^3.440.0",
    "@aws-sdk/client-bedrock-runtime": "^3.440.0",
    "@aws-sdk/client-dynamodb": "^3.440.0",
    "@aws-sdk/client-s3": "^3.440.0",
    "@aws-sdk/client-cloudwatch
    "@aws-sdk/client-bedrock": "^3.440.0",
    "@aws-sdk/client-bedrock-runtime": "^3.440.0",
    "@aws-sdk/client-dynamodb": "^3.440.0",
    "@aws-sdk/client-s3": "^3.440.0",
    "@aws-sdk/lib-dynamodb": "^3.440.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.0.1",
    "@vitest/coverage-v8": "^1.0.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  }
}
